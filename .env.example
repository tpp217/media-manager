# media-manager 環境変数テンプレート（値は空。実際の値は Doppler / Vercel で管理）
# ローカルにはこのファイルをコピーして .env を作るが、運用は Vercel 上で行う方針。

# ── Supabase（media 系統 DB / service_role はサーバー限定・クライアントへ露出禁止） ──
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
# anon / publishable キー（公開可）。単体版（STANDALONE）のローカルログインで使う。
# /login がブラウザで signInWithPassword し、サーバーは /auth/v1/user で token を検証する。
# SUPABASE_ANON_KEY が無ければ SUPABASE_PUBLISHABLE_KEY を使う（新旧キー形式の両対応）。
SUPABASE_ANON_KEY=

# ── セッション（既存の LINE SSO HMAC Cookie 用） ──
SESSION_SECRET=

# ── 認証ゲート（workspace-hub の JWT を JWKS 検証 / F5） ──
# 既定は「監視のみ」でブロックしない。値を入れなくても現挙動のまま動く（非破壊）。
# AUTH_ENFORCE    "on" にすると未認証 / 検証失敗 / 権限不足を 401/403 でブロック。未設定/off は監視のみ
# AUTH_SYSTEM_KEY 自アプリのシステムキー（未設定なら "media"）。enforce 時 JWT の systems[] と照合
#                 ※ workspace-hub の system_access.system_key と一致が必要。enforce 前に要確認
# JWKS_URL        JWKS エンドポイント（未設定なら https://auth.utinc.dev/.well-known/jwks.json）
# AUTH_EXPECTED_ISSUER 期待する JWT 発行元（iss）。未設定なら https://auth.utinc.dev（workspace-hub 固定）。
#                 署名のみでなく iss も照合し、別発行元トークンのなりすましを防ぐ（非破壊・既定で設定不要）
# AUTH_ENFORCE=off
# AUTH_SYSTEM_KEY=media
# JWKS_URL=https://auth.utinc.dev/.well-known/jwks.json
# AUTH_EXPECTED_ISSUER=https://auth.utinc.dev

# ── 動作モード（単体販売版 / STANDALONE） ──
# 既定（STANDALONE 未設定）＝プラットフォーム版＝現挙動を一切変えない（後方互換）。
# STANDALONE=true のときだけ単体版の分岐が効く（ON は 1/true/on/yes のいずれか・それ以外は false）。
#
# STANDALONE          単体版にするフラグ。true で:
#                       - wh SSO 監視/enforce ゲートを使わず、自前ローカルログインの
#                         media_session（HMAC cookie）を必須にしてアクセスを塞ぐ
#                       - 未認証なら wh SSO ではなく /login（自前ログイン）へ誘導する
#                       - テナントは下記 STANDALONE_TENANT_ID に固定
#                     ※ ログイン: /login が Supabase Auth（email/password）で本人確認し、
#                       /api/auth/standalone-login が token を検証して media_session を発行する。
#                       初期ユーザーは Supabase ダッシュボード（Authentication > Users）で作成する。
# STANDALONE_TENANT_ID 単体版で全データを紐づける固定テナント ID（単一顧客＝1 テナント）。
#                      STANDALONE=true のとき必須（未設定だと resolveTenant が fail-closed で 403）。
# STANDALONE=true
# STANDALONE_TENANT_ID=
