# media-manager 環境変数テンプレート（値は空。実際の値は Doppler / Vercel で管理）
# ローカルにはこのファイルをコピーして .env を作るが、運用は Vercel 上で行う方針。

# ── Supabase（media 系統 DB / service_role はサーバー限定・クライアントへ露出禁止） ──
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── セッション（既存の LINE SSO HMAC Cookie 用） ──
SESSION_SECRET=

# ── 認証ゲート（workspace-hub の JWT を JWKS 検証 / F5） ──
# 既定は「監視のみ」でブロックしない。値を入れなくても現挙動のまま動く（非破壊）。
# AUTH_ENFORCE    "on" にすると未認証 / 検証失敗 / 権限不足を 401/403 でブロック。未設定/off は監視のみ
# AUTH_SYSTEM_KEY 自アプリのシステムキー（未設定なら "media"）。enforce 時 JWT の systems[] と照合
#                 ※ workspace-hub の system_access.system_key と一致が必要。enforce 前に要確認
# JWKS_URL        JWKS エンドポイント（未設定なら https://auth.utinc.dev/.well-known/jwks.json）
# AUTH_ENFORCE=off
# AUTH_SYSTEM_KEY=media
# JWKS_URL=https://auth.utinc.dev/.well-known/jwks.json
