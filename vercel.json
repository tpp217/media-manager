{
  "github": {
    "silent": false
  },
  "rewrites": [
    { "source": "/login", "destination": "/login.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://utinc.dev https://*.utinc.dev https://*.vercel.app"
        }
      ]
    }
  ]
}
